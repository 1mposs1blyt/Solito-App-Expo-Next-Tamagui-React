{
  "name": "solito-blank",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@tamagui/babel-plugin": "^2.0.0-rc.41",
    "@tamagui/next-plugin": "^2.0.0-rc.41",
    "@types/react": "^18.2.21",
    "@types/react-native": "^0.73.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.21.0",
    "turbo": "^2.4.4",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "native": "cd apps/expo && yarn start",
    "web": "cd apps/next && yarn next"
  },
  "eslintConfig": {
    "extends": "next",
    "settings": {
      "next": {
        "rootDir": "apps/next/"
      }
    },
    "root": true
  },
  "prettier": {
    "semi": false,
    "useTabs": false,
    "tabWidth": 2,
    "singleQuote": true
  },
  "dependencies": {
    "@react-native-menu/menu": "^2.0.0",
    "@tamagui/config": "^2.0.0-rc.41",
    "@tamagui/lucide-icons": "2.0.0-rc.26",
    "babel-plugin-transform-inline-environment-variables": "^0.4.4",
    "babel-preset-expo": "^55.0.17",
    "react-native-ios-context-menu": "^3.2.1",
    "react-native-ios-utilities": "^5.2.0",
    "react-native-svg": "^15.15.4",
    "react-native-worklets-core": "^1.6.3",
    "tamagui": "^2.0.0-rc.41"
  }
}
